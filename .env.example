# Server
HOST=0.0.0.0
PORT=8080
SELF_URL=https://example.mctai.app
ALLOWED_CORS_ORIGIN=https://example.mctai.app
RUST_LOG=info

# PostgreSQL
DATABASE_URL=postgresql://app_user:app_password@postgres.example.internal:5432/app_db?sslmode=require

# Ideavibes auth service
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=app_example-token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json

# Ideavibes email service
MCTAI_EMAIL_URL=https://email.mctai.app/send
MCTAI_EMAIL_APP_TOKEN=email_app_example-token

# Object storage
OBJECT_STORAGE_ENDPOINT=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_BUCKET=creator-posts-example
OBJECT_STORAGE_ACCESS_KEY_ID=example-access-key
OBJECT_STORAGE_SECRET_ACCESS_KEY=example-secret-key
OBJECT_STORAGE_PREFIX=app/example/

# Instagram app credentials
INSTAGRAM_CLIENT_ID=1234567890
INSTAGRAM_CLIENT_SECRET=example-instagram-client-secret
INSTAGRAM_REDIRECT_URI=https://example.mctai.app/api/instagram/callback
INSTAGRAM_OAUTH_AUTH_URL=https://api.instagram.com/oauth/authorize
INSTAGRAM_OAUTH_TOKEN_URL=https://api.instagram.com/oauth/access_token
INSTAGRAM_LONG_LIVED_TOKEN_URL=https://graph.instagram.com/access_token
INSTAGRAM_REFRESH_TOKEN_URL=https://graph.instagram.com/refresh_access_token
INSTAGRAM_OAUTH_SCOPES=instagram_business_basic
CREDENTIAL_ENCRYPTION_KEY=base64-encoded-32-byte-key

# Image and caption generation
OPENAI_API_KEY=sk-example
OPENAI_IMAGE_GENERATION_URL=https://api.openai.com/v1/images/generations
IMAGE_GENERATION_MODEL=gpt-image-1-mini
IMAGE_GENERATION_SIZE=1024x1024
IMAGE_GENERATION_QUALITY=low
IMAGE_GENERATION_FORMAT=png
CAPTION_GENERATION_MODEL=gpt-4.1-mini

# Royalty-free stock image fallback
STOCK_IMAGE_PROVIDER=pexels
PEXELS_API_KEY=example-pexels-api-key
PEXELS_SEARCH_URL=https://api.pexels.com/v1/search
STOCK_IMAGE_PER_PAGE=10
